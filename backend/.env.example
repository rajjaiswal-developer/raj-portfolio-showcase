# ── SERVER ────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── DATABASE ──────────────────────────────────────
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/raj-portfolio

# ── JWT AUTH ──────────────────────────────────────
# Use a long random string — generate at: https://randomkeygen.com
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRE=30d

# ── ADMIN LOGIN ───────────────────────────────────
ADMIN_EMAIL=admin@rajjaiswal.dev
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# ── RAZORPAY ──────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── CLOUDINARY ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS — YOUR DEPLOYED URLS ─────────────────────
FRONTEND_URL=https://www.rajjaiswal.dev
ADMIN_URL=https://admin.rajjaiswal.dev
